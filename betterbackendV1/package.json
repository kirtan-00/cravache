{
  "name": "cravache-betterbackend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CravAche — modern-vanilla build (Vite + TS + PWA + Howler + GSAP). No framework: the imperative canvas game is preserved exactly; the toolchain wraps it.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "howler": "^2.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "@types/howler": "^2.2.12",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
